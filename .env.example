# Copy this file to .env and fill local values.

# OpenAI-compatible LLM endpoint. Leave empty if only running non-LLM checks.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Alternative providers used by some local experiments.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DASHSCOPE_API_KEY=
DASHSCOPE_VISION_MODEL=qwen-vl-max

# Habitat / ObjectNav paths.
HABITAT_DATA_PATH=data
HABITAT_CONFIG_PATH=benchmark/nav/objectnav/objectnav_hm3d.yaml
PIXNAV_HABITAT_ROOT_DIR=
PIXNAV_HM3D_CONFIG_PATH=
PIXNAV_SCENE_PREFIX=data/scene_datasets/
PIXNAV_EPISODE_PREFIX=data/datasets/

# Runtime defaults.
HABITAT_GPU_DEVICE_ID=0
ADA_SEMNAV_PYTHON_BIN=
